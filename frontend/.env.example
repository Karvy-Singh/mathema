VITE_API_BASE_URL=/api/v1

# 데모 자동 로그인 — 시드 계정으로 자동 진입.
# 개발·내부 데모 환경에서만 true. Play 빌드 / production 에는 무조건 false (또는 미설정).
VITE_ENABLE_DEMO_AUTO_LOGIN=true

# 데모 시드 계정 (백엔드 prisma/seed.ts 와 일치)
VITE_DEMO_EMAIL=polopot123@gmail.com
VITE_DEMO_PASSWORD=password1234

# Google Sign-In OAuth Web Client ID (Cloud Console > Credentials).
# 미설정 시 Google 버튼 비활성화 (이메일 로그인만 동작).
VITE_GOOGLE_CLIENT_ID=

# Sentry — 미설정이면 SDK no-op.
VITE_SENTRY_DSN=
