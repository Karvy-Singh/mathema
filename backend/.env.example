# ===== App =====
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:5173
ADMIN_ORIGIN=http://localhost:5174

# ===== PostgreSQL =====
DATABASE_URL=postgresql://mathema:mathema@localhost:5432/mathema?schema=public

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== JWT =====
# production (NODE_ENV=production) 에서는 부팅 시 placeholder/약한 시크릿 거부됨.
# 새 시크릿 생성: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# access != refresh 여야 함. 32자 이상.
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=14d

# ===== Admin =====
# 콤마 구분 — 어드민 페이지 접근 허용 이메일.
ADMIN_EMAILS=polopot123@gmail.com

# ===== Mail (선택) =====
# 미설정 시 [MAIL stub] 로그로 토큰 출력. 운영 전환 시 SMTP/SendGrid 연결.
MAIL_FROM=noreply@matheo.ai

# ===== Google Sign-In (선택) =====
GOOGLE_CLIENT_ID=

# ===== Sentry (선택) =====
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== Firebase / FCM (선택, 푸시) =====
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ===== AI (api입력칸) =====
# 여기에 실제 발급 받은 키를 채워 넣는다.
# 모든 LLM/Vision/Embedding 호출은 src/infrastructure/ai/providers/* 에서만 사용한다.
AI_LLM_PROVIDER=anthropic            # anthropic | openai
AI_LLM_API_KEY=api입력칸
AI_LLM_MODEL=claude-opus-4-7

AI_VISION_PROVIDER=openai            # openai | google
AI_VISION_API_KEY=api입력칸
AI_VISION_MODEL=gpt-4o

AI_EMBEDDING_PROVIDER=openai
AI_EMBEDDING_API_KEY=api입력칸
AI_EMBEDDING_MODEL=text-embedding-3-large

# ===== Storage =====
STORAGE_DRIVER=local                 # local | s3
STORAGE_LOCAL_DIR=./uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
